{
  "name": "infinity-comfyui",
  "private": true,
  "version": "5.23.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/electron-dev.mjs launcher",
    "dev:electron": "node scripts/electron-dev.mjs electron",
    "dev:renderer": "vite --host 127.0.0.1 --port 7930 --strictPort",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "serve": "node server/serve.mjs",
    "docker:build": "docker build -t infinity-comfyui:local .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:export": "node scripts/export-docker-release.mjs",
    "electron": "npm run build && electron .",
    "launcher": "npm run build && electron electron/launcher.cjs",
    "package:electron": "npm run build && electron-builder --config electron-builder.electron.cjs --win",
    "package:launcher": "npm run build && electron-builder --config electron-builder.launcher.cjs --win",
    "package:electron:only": "electron-builder --config electron-builder.electron.cjs --win",
    "package:launcher:only": "electron-builder --config electron-builder.launcher.cjs --win",
    "package:win": "npm run build && electron-builder --win --config electron-builder.electron.cjs && electron-builder --win --config electron-builder.launcher.cjs"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.infinitycomfyui.workstation",
    "productName": "Infinity ComfyUI",
    "files": [
      "app-dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "dompurify": "^3.4.12",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.6",
    "nanoid": "^5.1.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
